{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Frontend (Next.js)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["next", "dev"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "Backend (FastAPI)",
      "runtimeExecutable": "agent/.venv/Scripts/uvicorn.exe",
      "runtimeArgs": ["backend.main:app", "--host", "127.0.0.1", "--port", "8001"],
      "port": 8001
    }
  ]
}
